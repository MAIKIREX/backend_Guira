# -------------------------------------------------------------
# Guira Backend API - Entorno de Desarrollo (Development)
# -------------------------------------------------------------

# Puerto del servidor NestJS
PORT=3001

# Prefijo global de la API (ej: "api/v1" o "api")
PATH_SUBDOMAIN=api

# Orígenes permitidos para CORS (separados por coma)
URL_FRONTEND=http://localhost:3000,http://localhost:5173

# -------------------------------------------------------------
# SUPABASE BAAS (Base de Datos + Auth)
# -------------------------------------------------------------
# URL raíz del proyecto Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# IMPORTANTE: Usar SERVICE ROLE KEY en backend, núnca el ANON KEY.
# El Service Role permite saltar las reglas de RLS en operaciones CRON/Admin.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------------------------
# BRIDGE API (Procesamiento de pagos y creación de cuentas US)
# -------------------------------------------------------------
# Base URL (Usar sandbox para desarrollo, production para prod)
BRIDGE_API_URL=https://api.sandbox.bridge.xyz/v0

# API Key generada desde el dashboard de desarrollador de Bridge
BRIDGE_API_KEY=sk_test_...

# Secreto de validación de los Webhooks de Bridge (HMAC-SHA256)
BRIDGE_WEBHOOK_SECRET=whsec_...
